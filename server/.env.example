# ── VCC Server Environment Variables ──────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── App ───────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
DB_PATH=./data/vcc.db

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=<generate-a-strong-random-string>
JWT_EXPIRES_IN=2h

# ── CORS ──────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://cardgolink.com,https://admin.cardgolink.com,https://api.cardgolink.com

# ── URLs ──────────────────────────────────────────────────────────
API_BASE=http://localhost:3001
CLIENT_BASE_URL=https://cardgolink.com
API_BASE_URL=https://api.cardgolink.com
CLIENT_URL=https://cardgolink.com

# ── Wallet USDT→USD Conversion (disabled by default) ────────────
ENABLE_WALLET_CONVERT=false
# 灰度测试用户 ID（逗号分隔），留空表示所有人都可用（需 ENABLE_WALLET_CONVERT=true）
WALLET_CONVERT_TEST_USER_IDS=2,13
# USDT→USD 兑换汇率（默认 1:1）
USDT_TO_USD_RATE=1.0

# ── Admin (production only: required when admins table is empty) ──
ADMIN_USERNAME=<admin-username>
ADMIN_PASSWORD=<strong-password-min-8-chars>

# ── SMTP (Email Verification) ────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=<your-smtp-user>
SMTP_PASS=<your-smtp-password>
RESEND_FROM=noreply@example.com

# -- UQPay real recharge guard --
ENABLE_UQPAY_REAL_RECHARGE=false
UQPAY_RECHARGE_TEST_USER_IDS=

# -- UQPay recharge limits (P0) --
# 单笔充值金额下限（默认 $10）
UQPAY_RECHARGE_MIN_AMOUNT=10
# 单笔充值金额上限（默认 $5,000）
UQPAY_RECHARGE_MAX_AMOUNT=5000
# 用户每日累计充值金额上限（默认 $10,000）
UQPAY_RECHARGE_DAILY_LIMIT=10000
# 用户每日充值次数上限（默认 10 次）
UQPAY_RECHARGE_DAILY_COUNT_LIMIT=10
# 单卡每日累计充值金额上限（默认 $5,000）
UQPAY_RECHARGE_CARD_DAILY_LIMIT=5000
# 单卡每日充值次数上限（默认 5 次）
UQPAY_RECHARGE_CARD_DAILY_COUNT=5
# 用户 PENDING 订单并发上限（默认 3 笔）
UQPAY_RECHARGE_USER_PENDING_MAX=3
# 连续失败次数上限（超过后冻结，默认 3 次）
UQPAY_RECHARGE_MAX_CONSECUTIVE_FAILURES=3
# 失败冻结时长（分钟，默认 30 分钟）
UQPAY_RECHARGE_FAILURE_FREEZE_MINUTES=30
