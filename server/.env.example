# ── VCC Server Environment Variables ──────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── App ───────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
DB_PATH=./data/vcc.db

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=<generate-a-strong-random-string>
JWT_EXPIRES_IN=2h

# ── CORS ──────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://cardgolink.com,https://admin.cardgolink.com,https://api.cardgolink.com

# ── URLs ──────────────────────────────────────────────────────────
API_BASE=http://localhost:3001
CLIENT_BASE_URL=https://cardgolink.com
API_BASE_URL=https://api.cardgolink.com
CLIENT_URL=https://cardgolink.com

# ── Wallet USDT→USD Conversion (disabled by default) ────────────
ENABLE_WALLET_CONVERT=false
# 灰度测试用户 ID（逗号分隔），留空表示所有人都可用（需 ENABLE_WALLET_CONVERT=true）
WALLET_CONVERT_TEST_USER_IDS=2,13
# USDT→USD 兑换汇率（默认 1:1）
USDT_TO_USD_RATE=1.0

# ── Admin (production only: required when admins table is empty) ──
ADMIN_USERNAME=<admin-username>
ADMIN_PASSWORD=<strong-password-min-8-chars>

# ── SMTP (Email Verification) ────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=<your-smtp-user>
SMTP_PASS=<your-smtp-password>
RESEND_FROM=noreply@example.com

# -- UQPay real recharge guard --
ENABLE_UQPAY_REAL_RECHARGE=false
UQPAY_RECHARGE_TEST_USER_IDS=
